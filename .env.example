# Environment Configuration
# Copy this to .env and fill in values

# Base URL of the Mendix application to test
BASE_URL=https://companysampleapp.mxapps.io

# LLM Configuration (OpenAI Compatible)
# Set LLM_BASE_URL to use Azure, local models (Ollama/vLLM), etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Langfuse Observability
# Visit https://cloud.langfuse.com to get your keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Headless browser mode (true/false)
HEADLESS=true

# Self-heal max retries
MAX_RETRIES=3

# Slow down actions for debugging (ms)
SLOW_MO=2
